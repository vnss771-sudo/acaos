+#!/usr/bin/env node
+import { readdirSync, readFileSync, statSync } from 'node:fs'
+import { join, relative } from 'node:path'
+
+const root = process.cwd()
+const webSrc = join(root, 'apps', 'web', 'src')
+const violations = []
+
+function walk(dir) {
+  for (const entry of readdirSync(dir)) {
+    const path = join(dir, entry)
+    const stat = statSync(path)
+    if (stat.isDirectory()) {
+      walk(path)
+      continue
+    }
+    if (!/\.(ts|tsx)$/.test(entry)) continue
+    if (/\.test\.(ts|tsx)$/.test(entry)) continue
+    if (path.endsWith(join('apps', 'web', 'src', 'lib', 'apiContract.ts'))) continue
+
+    const text = readFileSync(path, 'utf8')
+    const lines = text.split(/\r?\n/)
+    lines.forEach((line, idx) => {
+      if (/body\s*:\s*JSON\.stringify\s*\(/.test(line)) {
+        violations.push(`${relative(root, path)}:${idx + 1}: use jsonBody('<METHOD> <ROUTE>', body) instead of raw JSON.stringify for API bodies`)
+      }
+    })
+  }
+}
+
+walk(webSrc)
+
+if (violations.length) {
+  console.error('API contract check failed. Untyped request bodies found:')
+  for (const v of violations) console.error(`  - ${v}`)
+  process.exit(1)
+}
+
+console.log('✓ API contract check passed — production web API bodies use typed route contracts.')
