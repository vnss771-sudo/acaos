+const boundedString = (max: number) => z.string().trim().min(1).max(max)
+
+export const leadResearchResultSchema = z.object({
+  aiSummary: boundedString(1_500),
+  outreachAngle: boundedString(300),
+  qualificationSignals: z.array(boundedString(300)).min(0).max(5),
+  icpScore: z.number().finite().min(0).max(100),
+  hiringSignals: z.boolean(),
+  digitalMaturity: z.enum(['low', 'medium', 'high']),
+  estimatedTeamSize: z.enum(['1-10', '10-50', '50-200', '200-500', '500+']),
+}).strict()
+
+export const outreachResultSchema = z.object({
+  subject: boundedString(120),
+  email: boundedString(2_000),
+  followup: boundedString(1_500),
+}).strict()
+
+export const replyAnalysisResultSchema = z.object({
+  classification: z.enum([
+    'INTERESTED',
+    'NOT_INTERESTED',
+    'NEEDS_MORE_INFO',
+    'NOT_NOW',
+    'OUT_OF_OFFICE',
+    'REFERRAL',
+  ]),
+  confidence: z.number().finite().min(0).max(100),
+  summary: boundedString(1_000),
+  suggestedAction: boundedString(1_000),
+  urgency: z.enum(['immediate', 'this_week', 'this_month', 'nurture', 'never']),
+  keyQuote: z.string().trim().max(300),
+  isAutoReply: z.boolean(),
+}).strict()
+
+export type LeadResearchResult = z.infer<typeof leadResearchResultSchema>
+export type OutreachResult = z.infer<typeof outreachResultSchema>
+export type ReplyAnalysisResult = z.infer<typeof replyAnalysisResultSchema>
+
+function formatZodIssues(err: z.ZodError): string {
+  return err.issues
+    .map(issue => `${issue.path.join('.') || 'root'}: ${issue.message}`)
+    .slice(0, 5)
+    .join('; ')
+}
+
+/**
+ * Strictly validates model JSON before it reaches persistence or workflow
+ * branches. A malformed/partial model response is treated as a 502 provider
+ * fault so BullMQ can retry instead of silently writing nulls or wrong stages.
+ */
+function parseAiJson<T>(raw: string, schema: z.ZodType<T>, label: string): T {
+  let parsed: unknown
+  try {
+    parsed = JSON.parse(raw)
+  } catch {
+    throw new ApiError(502, `${label} returned invalid JSON`)
+  }
+
+  const result = schema.safeParse(parsed)
+  if (!result.success) {
+    throw new ApiError(502, `${label} JSON failed validation: ${formatZodIssues(result.error)}`)
+  }
+
+  return result.data
+}
+
+export function parseLeadResearchJson(raw: string): LeadResearchResult {
+  return parseAiJson(raw, leadResearchResultSchema, 'AI lead research')
+}
+
+export function parseOutreachJson(raw: string): OutreachResult {
+  return parseAiJson(raw, outreachResultSchema, 'AI outreach')
+}
+
+export function parseReplyAnalysisJson(raw: string): ReplyAnalysisResult {
+  return parseAiJson(raw, replyAnalysisResultSchema, 'AI reply analysis')
+}
