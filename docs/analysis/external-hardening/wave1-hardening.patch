+// Bounded fetch wrapper for external providers.
+//
+// Native fetch has no default timeout. Provider calls that forget AbortController
+// can pin API/worker capacity indefinitely during DNS/TLS/socket hangs. Keep the
+// helper dependency-free so it can be used by both API-only integrations and
+// backend-core services.
+
+export type ExternalFetchOptions = {
+  /** Human-readable provider name used in thrown timeout messages. */
+  label?: string
+  /** Request timeout. Defaults to EXTERNAL_HTTP_TIMEOUT_MS or 15s. */
+  timeoutMs?: number
+  /** Number of retries after the first attempt. Defaults to 1. */
+  retries?: number
+  /** Initial backoff delay between retries. Defaults to 250ms. */
+  retryDelayMs?: number
+  /** HTTP statuses worth retrying. Defaults to 408, 409, 425, 429 and 5xx. */
+  retryStatuses?: number[]
+}
+
+export class ExternalHttpTimeoutError extends Error {
+  constructor(public readonly label: string, public readonly timeoutMs: number) {
+    super(`${label} request timed out after ${timeoutMs}ms`)
+    this.name = 'ExternalHttpTimeoutError'
+  }
+}
+
+function defaultTimeoutMs(): number {
+  const raw = Number(process.env.EXTERNAL_HTTP_TIMEOUT_MS || 15_000)
+  return Number.isFinite(raw) && raw > 0 ? raw : 15_000
+}
+
+function defaultRetries(): number {
+  const raw = Number(process.env.EXTERNAL_HTTP_RETRIES ?? 1)
+  return Number.isFinite(raw) && raw >= 0 ? Math.floor(raw) : 1
+}
+
+function retryableStatus(status: number, explicit?: number[]): boolean {
+  if (explicit?.includes(status)) return true
+  return status === 408 || status === 409 || status === 425 || status === 429 || status >= 500
+}
+
+function retryableError(err: unknown): boolean {
+  if (err instanceof ExternalHttpTimeoutError) return true
+  if (!(err instanceof Error)) return false
+  // Node/undici network failures commonly surface as TypeError("fetch failed").
+  return err.name === 'AbortError' || err.name === 'TypeError'
+}
+
+function sleep(ms: number): Promise<void> {
+  return new Promise(resolve => setTimeout(resolve, ms))
+}
+
+function withAbortTimeout(init: RequestInit, timeoutMs: number, label: string): { init: RequestInit; clear: () => void } {
+  const controller = new AbortController()
+  const parentSignal = init.signal
+
+  if (parentSignal) {
+    if (parentSignal.aborted) controller.abort(parentSignal.reason)
+    else parentSignal.addEventListener('abort', () => controller.abort(parentSignal.reason), { once: true })
+  }
+
+  const timer = setTimeout(() => controller.abort(new ExternalHttpTimeoutError(label, timeoutMs)), timeoutMs)
+  timer.unref?.()
+
+  return {
+    init: { ...init, signal: controller.signal },
+    clear: () => clearTimeout(timer),
+  }
+}
+
+/**
+ * Fetch with explicit timeout and bounded retries.
+ *
+ * The returned Response is the final provider response. Non-OK responses are not
+ * converted to exceptions so callers can preserve existing provider-specific
+ * error handling; only network/timeout failures throw.
+ */
+export async function fetchWithTimeout(
+  input: string | URL,
+  init: RequestInit = {},
+  options: ExternalFetchOptions = {}
+): Promise<Response> {
+  const label = options.label ?? (typeof input === 'string' ? input : input.hostname)
+  const timeoutMs = options.timeoutMs ?? defaultTimeoutMs()
+  const retries = options.retries ?? defaultRetries()
+  const retryDelayMs = options.retryDelayMs ?? 250
+
+  let lastError: unknown
+
+  for (let attempt = 0; attempt <= retries; attempt++) {
+    const wrapped = withAbortTimeout(init, timeoutMs, label)
+    try {
+      const res = await fetch(input, wrapped.init)
+
+      if (attempt < retries && retryableStatus(res.status, options.retryStatuses)) {
+        // Drain the body before retrying so undici can reuse/free the connection.
+        // Keep the timeout active while draining; a stalled response body is just
+        // as dangerous as a stalled response header.
+        await res.arrayBuffer().catch(() => undefined)
+        wrapped.clear()
+        await sleep(retryDelayMs * Math.pow(2, attempt))
+        continue
+      }
+
+      wrapped.clear()
+      return res
+    } catch (err) {
+      wrapped.clear()
+      const abortedByTimeout = err instanceof ExternalHttpTimeoutError
+        || (err instanceof Error && err.name === 'AbortError')
+
+      lastError = abortedByTimeout
+        ? new ExternalHttpTimeoutError(label, timeoutMs)
+        : err
+
+      if (attempt >= retries || !retryableError(lastError)) throw lastError
+      await sleep(retryDelayMs * Math.pow(2, attempt))
+    }
+  }
+
+  throw lastError
+}
