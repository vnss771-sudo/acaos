{
  "name": "@acaos/backend-core",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./lib/*.js": {
      "acaos-src": "./src/lib/*.ts",
      "types": "./dist/lib/*.d.ts",
      "default": "./dist/lib/*.js"
    },
    "./services/*.js": {
      "acaos-src": "./src/services/*.ts",
      "types": "./dist/services/*.d.ts",
      "default": "./dist/services/*.js"
    }
  },
  "scripts": {
    "build": "npx prisma generate --schema ../../packages/db/prisma/schema.prisma && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "bullmq": "^5.12.12",
    "imapflow": "^1.0.181",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^9.0.1",
    "openai": "^6.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
