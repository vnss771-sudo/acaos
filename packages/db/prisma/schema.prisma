generator client {
  provider = "prisma-client-js"
  // Generate the musl/openssl-3 query engine explicitly. The slim multi-stage
  // runtime images are alpine (musl) with openssl 3; without this, generate can
  // fall back to the openssl-1.1.x engine, which then fails at load with
  // "libssl.so.1.1: No such file". "native" keeps local/glibc CI working.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Append-only audit log of significant actions (sends, approvals, mission status
// changes, provider failures, api-key rotations). Deliberately FK-free so history
// survives deletion of the referenced entity.
model AuditEvent {
  id          String   @id @default(cuid())
  workspaceId String?
  actorUserId String?
  type        String
  entityType  String?
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([workspaceId, createdAt])
  @@index([type, createdAt])
  // Standalone time index for the global retention purge (createdAt < cutoff),
  // which the workspace-/type-first compounds above can't serve.
  @@index([createdAt])
}

// Audit log for prospect-discovery runs so users can tell "no prospects" apart
// from "the provider failed / quota exceeded / not configured", and see what was
// searched, returned, imported, and skipped per run.
model DiscoveryRun {
  id            String    @id @default(cuid())
  workspaceId   String
  missionId     String?
  source        String
  status        DiscoveryRunStatus @default(RUNNING)
  query         Json?
  resultCount   Int       @default(0)
  importedCount Int       @default(0)
  skippedCount  Int       @default(0)
  errorCode     String?
  errorMessage  String?
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  mission       Mission?  @relation(fields: [missionId], references: [id], onDelete: SetNull)

  @@index([workspaceId, startedAt])
  @@index([missionId])
  // Standalone time index for the global retention purge (startedAt < cutoff).
  @@index([startedAt])
}

model User {
  id                  String                  @id @default(cuid())
  email               String                  @unique
  name                String?
  passwordHash        String?
  emailVerified       Boolean                 @default(false)
  // Platform (founder) admin access to the cross-tenant /api/admin panel. Set
  // out-of-band (not user-settable) — the gate must not rest on a mutable env
  // var alone. Defaults false so no account is admin unless explicitly granted.
  isPlatformAdmin     Boolean                 @default(false)
  // MFA (TOTP). totpSecret is stored encrypted at rest (EMAIL_ENCRYPTION_KEY).
  // totpEnabled flips true only after the user proves a code (activation), so a
  // half-finished setup never forces a second factor at login.
  totpSecret          String?
  totpEnabled         Boolean                 @default(false)
  // Step-up auth: timestamp of the most recent password (or MFA) proof. Sensitive
  // mutations (billing, admin, MFA disable) require this to be recent.
  lastReauthAt        DateTime?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  memberships         Membership[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  emailVerifications  EmailVerificationToken[]
}

model Workspace {
  id                   String               @id @default(cuid())
  name                 String
  slug                 String               @unique
  plan                 BillingPlan          @default(free)
  stripeCustomerId     String?              @unique
  stripeSubscriptionId String?              @unique
  subscriptionStatus   String?
  ingestApiKey         String?              @unique
  onboardingCompleted  Boolean              @default(false)
  senderBusinessName   String?
  senderPostalAddress  String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  memberships          Membership[]
  leads                Lead[]
  campaigns            Campaign[]
  outreachDrafts       OutreachDraft[]
  scoringModel         ScoringModel?
  usageRecords         UsageRecord[]
  prospects            Prospect[]
  signals              Signal[]
  recommendations      Recommendation[]
  outreachIntents      OutreachIntent[]
  prospectOutcomes     ProspectOutcome[]
  workspaceICP         WorkspaceICP?
  outreachSent         OutreachSent[]
  emailConfig          WorkspaceEmailConfig?
  invites              WorkspaceInvite[]
  suppressions         Suppression[]
  processedEmails      ProcessedEmail[]
  discoveryRuns        DiscoveryRun[]
  missions             Mission[]
  evidenceSources      EvidenceSource[]
  aiPromptVersions     AiPromptVersion[]
  draftPolicy          WorkspaceDraftPolicy?
}

model Membership {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  role        String
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([userId])
  @@index([workspaceId])
}

model Campaign {
  id           String         @id @default(cuid())
  workspaceId  String
  name         String
  goalType     String
  description  String?
  workspace    Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leads        Lead[]
  outreachSent OutreachSent[]
  mission      Mission?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([workspaceId])
}

// First-class Mission: the user-facing control plane that ties ICP/playbook,
// target + offer, and an execution Campaign into one workflow. The UI speaks
// "Mission"; this is its backing entity (previously the UI only created a
// Campaign). One Mission maps to one execution Campaign.
model Mission {
  id             String    @id @default(cuid())
  workspaceId    String
  name           String
  goalType       String
  targetCustomer String?
  offer          String?
  playbookId     String?
  status         MissionStatus @default(ACTIVE)
  campaignId     String?   @unique
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign       Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  discoveryRuns  DiscoveryRun[]
  prospects      Prospect[]

  @@index([workspaceId, status])
}

model Lead {
  id             String          @id @default(cuid())
  workspaceId    String
  campaignId     String?
  businessName   String
  contactName    String?
  email          String?
  phone          String?
  website        String?
  city           String?
  category       String?
  notes          String?
  aiSummary      String?
  outreachAngle  String?
  score          Int             @default(0)
  stage          LeadStage       @default(NEW)
  sourceTag      String?
  lastContactedAt DateTime?
  // Normalized email for dedupe (lowercased, plus-tag folded). Nullable: legacy
  // rows and leads without an email stay null.
  emailKey       String?
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign       Campaign?       @relation(fields: [campaignId], references: [id])
  outreachDrafts OutreachDraft[]
  outreachSent   OutreachSent[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, stage])
  @@index([workspaceId, email])
  @@index([workspaceId, emailKey])
  // Serves the default leads list (ORDER BY score DESC, createdAt DESC scoped to a
  // workspace) via a backward index scan instead of a full sort per request.
  @@index([workspaceId, score, createdAt])
  @@index([campaignId])
}

model OutreachDraft {
  id               String    @id @default(cuid())
  leadId           String
  workspaceId      String
  subject          String
  emailBody        String
  followup         String?
  status           DraftStatus @default(DRAFTED)
  promptVersionId  String?   // Which AI prompt/version generated this draft
  policyViolations Json?     // {violations: string[]} if policy check failed
  reviewedAt       DateTime?
  reviewedBy       String?   // userId of approver/rejecter
  createdAt        DateTime  @default(now())
  lead             Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  promptVersion    AiPromptVersion? @relation(fields: [promptVersionId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([promptVersionId])
}

// Tracks every email sent via a campaign — provides closed-loop reply correlation.
// messageId is the SMTP Message-ID header; mailbox sync matches inbound replies
// against this column to update status to REPLIED and trigger AI analysis.
model OutreachSent {
  id               String    @id @default(cuid())
  workspaceId      String
  campaignId       String?
  leadId           String?
  toEmail          String
  subject          String
  body             String
  messageId        String?   @unique  // SMTP Message-ID for reply correlation
  // Outbox lifecycle: SENDING (claimed, pre-dispatch) -> SENT, or -> FAILED on a
  // known SMTP rejection. A crash after dispatch leaves the row SENDING
  // (fail-closed: never auto-resend). PENDING reserved for future pre-stage.
  status           SendStatus @default(SENT)
  lastError        String?
  repliedAt        DateTime?
  replyIntent      String?
  // AI-derived reply metadata (Inbox/Replies). Populated by the analyze-reply
  // worker from the classifier output. The raw inbound body is intentionally
  // NOT stored — only these derived fields (privacy / retention).
  replySummary         String?
  replyKeyQuote        String?
  replySuggestedAction String?
  replyUrgency         String?
  replyConfidence      Int?
  replyIsAutoReply     Boolean?
  unsubscribeToken String?   @unique
  // Intelligence provenance (Stage 5): what intent/recommendation + evidence this
  // send was based on, snapshotted at send time so the record is self-auditable.
  outreachIntentId String?
  recommendationId String?
  evidenceSnapshot Json?
  sentAt           DateTime  @default(now())
  workspace        Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign         Campaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  lead             Lead?      @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([campaignId])
  @@index([leadId])
  @@index([toEmail])
  @@index([outreachIntentId])
  // Serves the per-workspace deliverability counters (status + window filters in
  // the campaigns/mission stats and the send loop).
  @@index([workspaceId, status, sentAt])
  // Standalone time index for the global retention purge (sentAt < cutoff), which
  // the workspace-first compound above can't serve.
  @@index([sentAt])
  // Outbox idempotency: at most one send row per (campaign, lead). Postgres
  // treats NULLs as distinct, so non-campaign/non-lead sends are unaffected.
  @@unique([campaignId, leadId])
}




// Persisted ScorerV2 model — one per workspace, survives deploys
model ScoringModel {
  id                 String           @id @default(cuid())
  workspaceId        String           @unique
  weights            Json
  signalWeights      Json?
  performanceMetrics Json
  updateCount        Int              @default(0)
  lastWeightUpdate   DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  workspace          Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  outcomes           ScoringOutcome[]
}

// Individual reply outcomes — feed the ScorerV2 feedback loop
model ScoringOutcome {
  id               String       @id @default(cuid())
  workspaceId      String
  leadId           String?
  // Nullable: reply outcomes sourced from a Lead (via the worker) have no
  // Prospect. Previously a Lead id was written here, corrupting the data.
  prospectId       String?
  score            Float
  replied          Boolean
  replyIntent      String?
  messageRelevance Float        @default(0.5)
  channelUsed      String       @default("EMAIL")
  scoringModelId   String
  scoringModel     ScoringModel @relation(fields: [scoringModelId], references: [id], onDelete: Cascade)
  recordedAt       DateTime     @default(now())

  @@index([workspaceId])
  @@index([scoringModelId])
  @@index([leadId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  // Retention purge scans createdAt < cutoff.
  @@index([createdAt])
}

// Monthly AI usage tracking for plan enforcement
model UsageRecord {
  id          String    @id @default(cuid())
  workspaceId String
  action      String    // AI_RESEARCH | AI_OUTREACH | AI_REPLY
  month       String    // YYYY-MM
  count       Int       @default(0)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, month, action])
  @@index([workspaceId])
  // Serves the admin cross-workspace usage rollups that filter by month alone.
  @@index([month])
}

// Deduplicate IMAP messages processed during mailbox sync.
// UIDs are only unique within a single mailbox, so they must be scoped by workspace.
model ProcessedEmail {
  id          String    @id @default(cuid())
  workspaceId String
  uid         Int
  messageId   String?
  fromAddress String?
  processedAt DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, uid])
  @@unique([workspaceId, messageId])
  @@index([workspaceId])
  // Retention purge scans processedAt < cutoff (workspace-agnostic).
  @@index([processedAt])
}

// Idempotency log for Stripe webhook events. Stripe delivers at-least-once and
// out of order; we record each processed event id so re-deliveries are ignored.
// Email invite for new users to join a workspace without a pre-existing account
model WorkspaceInvite {
  id          String    @id @default(cuid())
  workspaceId String
  email       String
  role        String    @default("member")
  tokenHash   String    @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, email])
  @@index([workspaceId])
}

// Per-workspace SMTP/IMAP credentials — falls back to env vars when absent
model WorkspaceEmailConfig {
  id          String    @id @default(cuid())
  workspaceId String    @unique
  smtpHost    String?
  smtpPort    Int?
  smtpSecure  Boolean   @default(false)
  smtpUser    String?
  smtpPass    String?
  smtpFrom    String?
  imapHost    String?
  imapPort    Int?
  imapSecure  Boolean   @default(true)
  imapUser    String?
  imapPass    String?
  // Reply-sync cursor: the highest IMAP UID processed for this workspace. Sync
  // fetches strictly above it (no fixed 200-message window), so a reply can never
  // be silently skipped after an outage or on a busy inbox. lastUidValidity pins
  // the mailbox's UIDVALIDITY — if it changes (mailbox reset/recreated), the
  // cursor is stale and is reset so old UIDs don't make us skip new mail.
  lastSyncedUid   Int       @default(0)
  lastUidValidity Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// Email address verification token sent on signup
model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  // Retention purge scans createdAt < cutoff.
  @@index([createdAt])
}

// Time-limited one-use token for password reset
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  // Retention purge scans createdAt < cutoff.
  @@index([createdAt])
}

model ProcessedStripeEvent {
  id          String   @id // Stripe event id (evt_...)
  type        String
  processedAt DateTime @default(now())

  // Retention purge scans processedAt < cutoff.
  @@index([processedAt])
}

enum SignalType {
  HIRING
  FUNDING
  EXPANSION
  TECH_ADOPTION
  LEADERSHIP_CHANGE
  NEWS_MENTION
  PROCUREMENT
  BUSINESS_REGISTRATION
  WEBSITE_CHANGE
}

enum BuyingStage {
  RESEARCHING
  EVALUATING
  COMPARING
  PURCHASING
  INACTIVE
}

enum OutcomeStage {
  DISCOVERED
  VIEWED
  CONTACTED
  MEETING
  PROPOSAL
  WON
  LOST
}

// Outreach draft review state (gates approval-mode sends).
enum DraftStatus {
  DRAFTED
  APPROVED
  REJECTED
  SENT
  SKIPPED
  // Draft generated but has policy violations; requires review before send.
  POLICY_REVIEW
}

enum MissionStatus {
  DRAFT
  DISCOVERING
  REVIEWING
  ACTIVE
  PAUSED
  COMPLETE
}

enum DiscoveryRunStatus {
  RUNNING
  SUCCEEDED
  PARTIAL
  FAILED
}

// Outbox send lifecycle for OutreachSent.
enum SendStatus {
  PENDING
  SENDING
  SENT
  FAILED
  BOUNCED
  REPLIED
}

// Workspace billing tier (was a free-form String — now DB-enforced). `free` is
// the default/lapsed tier; `starter` and `growth` are the paid Stripe plans.
enum BillingPlan {
  free
  starter
  growth
}

// Lead pipeline stage (was a free-form String — now DB-enforced).
enum LeadStage {
  NEW
  RESEARCHED
  OUTREACH_SENT
  REPLIED
  BOOKED
  CLOSED
  DEAD
}

model Suppression {
  id          String    @id @default(cuid())
  workspaceId String
  email       String
  reason      String    @default("UNSUBSCRIBED") // UNSUBSCRIBED | BOUNCED | MANUAL
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, email])
  @@index([workspaceId])
}

model Prospect {
  id               String       @id @default(cuid())
  workspaceId      String
  companyName      String
  domain           String?
  domainKey        String?      // normalized domain: lowercased, www-stripped
  // Normalized company name for dedupe (lowercased, punctuation/whitespace
  // collapsed, legal-entity suffix dropped). Nullable: legacy rows stay null.
  companyNameKey   String?
  // Normalized contact email for dedupe (lowercased, plus-tag folded). Nullable.
  emailKey         String?
  industry         String?
  employeeCount    Int?
  estimatedRevenue Int?    // cents
  location         String?
  description      String?
  notes            String?
  contactName      String?
  contactEmail     String?
  contactPhone     String?
  contactTitle     String?
  linkedinUrl      String?
  opportunityScore Int          @default(0)
  intentScore      Int          @default(0)
  fitScore         Int          @default(0)
  timingScore      Int          @default(0)
  confidenceScore  Int          @default(0)
  buyingStage      BuyingStage  @default(RESEARCHING)
  outcomeStage     OutcomeStage @default(DISCOVERED)
  expectedDealValue Int?   // cents
  winProbability   Float?
  lastSignalAt     DateTime?
  lastContactedAt  DateTime?
  aiSummary        String?
  sourceTag        String?
  isExample        Boolean      @default(false)
  // The mission this prospect was discovered for (if any). Lets the mission
  // control plane own its prospects, and carries through to recommendations.
  missionId        String?
  workspace        Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  mission          Mission?     @relation(fields: [missionId], references: [id], onDelete: SetNull)
  signals          Signal[]
  recommendations  Recommendation[]
  outcomes         ProspectOutcome[]
  evidenceSources  EvidenceSource[]
  outreachIntents  OutreachIntent[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, opportunityScore])
  @@index([workspaceId, buyingStage])
  @@index([workspaceId, outcomeStage])
  @@index([workspaceId, domainKey])
  @@index([workspaceId, companyNameKey])
  @@index([workspaceId, emailKey])
  @@index([missionId])
}

model Signal {
  id                String     @id @default(cuid())
  workspaceId       String
  prospectId        String
  evidenceSourceId  String?
  type              SignalType
  strength          Int
  sourceReliability Int        @default(70)
  industryRelevance Int        @default(50)
  title             String?
  description       String?
  sourceUrl         String?
  source            String?
  fingerprint       String?    // dedup key: source:type:title-slug:YYYY-MM
  rawData           Json?
  detectedAt        DateTime   @default(now())
  workspace         Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  prospect          Prospect   @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  evidenceSource    EvidenceSource? @relation(fields: [evidenceSourceId], references: [id], onDelete: SetNull)
  createdAt         DateTime   @default(now())

  @@unique([prospectId, fingerprint])
  @@index([workspaceId])
  @@index([prospectId])
  @@index([type])
  @@index([detectedAt])
  @@index([evidenceSourceId])
}

// Provenance for signals: where a piece of evidence came from, when it was
// observed, how trustworthy it is, and when it goes stale. Lets every signal /
// recommendation answer "what's the source?" — the basis for evidence-backed,
// auditable recommendations.
model EvidenceSource {
  id          String    @id @default(cuid())
  workspaceId String
  prospectId  String
  provider    String    // e.g. apollo | places | hunter | manual | crawler
  sourceType  String    // e.g. job_posting | website | news | tender | review
  sourceUrl   String?
  observedAt  DateTime  @default(now())
  expiresAt   DateTime?
  confidence  Float     @default(0.5) // 0..1
  rawText     String?
  metadata    Json?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  prospect    Prospect  @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  signals     Signal[]

  @@index([workspaceId, prospectId])
  @@index([provider, observedAt])
}

model Recommendation {
  id           String    @id @default(cuid())
  workspaceId  String
  prospectId   String
  bestContact  String?
  bestTiming   String?
  bestChannel  String?
  messageAngle String?
  reasoning    String?
  actionText   String?
  urgency      String    @default("MEDIUM")
  priority     Int       @default(50)
  expiresAt    DateTime?
  actedAt      DateTime?
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  prospect     Prospect  @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  outreachIntent OutreachIntent?
  createdAt    DateTime  @default(now())

  @@index([workspaceId])
  @@index([prospectId])
}

// Bridge between the prospect-intelligence track (Recommendation) and the
// outreach/send track (Lead/Campaign/OutreachSent). Carries a recommendation +
// an evidence snapshot through the draft → approval → send → outcome lifecycle
// as one auditable record. Stage 1: schema only (not yet wired).
enum OutreachIntentStatus {
  PROPOSED
  DRAFTED
  APPROVED
  QUEUED
  SENT
  WON
  LOST
  REJECTED
}

model OutreachIntent {
  id               String   @id @default(cuid())
  workspaceId      String
  prospectId       String
  recommendationId String?  @unique
  // Plain scalar links into the send track (no FK yet) — set when an approved
  // intent is materialised for sending; kept loose to avoid coupling Stage 1.
  leadId           String?
  campaignId       String?
  missionId        String?
  status           OutreachIntentStatus @default(PROPOSED)
  messageAngle     String?
  channel          String?
  evidenceSnapshot Json?
  // Draft generated from the intent's evidence (Stage 3). Held on the intent so
  // it stays self-contained until an approved intent is materialised for sending.
  draftSubject     String?
  draftBody        String?
  draftFollowup    String?
  draftGeneratedAt DateTime?
  approvedBy       String?
  approvedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  prospect       Prospect        @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  recommendation Recommendation? @relation(fields: [recommendationId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([prospectId])
  @@index([missionId])
}

model ProspectOutcome {
  id          String       @id @default(cuid())
  workspaceId String
  prospectId  String
  stage       OutcomeStage
  notes       String?
  dealValue   Int?      // cents
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  prospect    Prospect     @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  recordedAt  DateTime     @default(now())

  @@index([workspaceId])
  @@index([prospectId])
}

model AiPromptVersion {
  id           String    @id @default(cuid())
  workspaceId  String
  type         String    // OUTREACH | REPLY_ANALYSIS | SCORING | RECOMMENDATIONS
  version      Int       // auto-increment per (workspace, type)
  promptHash   String    // SHA-256 hash of prompt template
  model        String    // gpt-4-turbo | gpt-4o | claude-3-sonnet etc.
  maxTokens    Int?
  temperature  Float?
  metadata     Json?     // {tags: ["safe-launch"], author: "system"} etc.
  isActive     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  drafts       OutreachDraft[]

  @@unique([workspaceId, type, version])
  @@index([workspaceId, type, isActive])
  @@index([promptHash])
}

model WorkspaceDraftPolicy {
  id                   String    @id @default(cuid())
  workspaceId          String    @unique
  minSubjectLength     Int       @default(5)
  maxSubjectLength     Int       @default(80)
  minBodyLength        Int       @default(30)
  maxBodyLength        Int       @default(3000)
  forbiddenPhrases     String[]  @default([])
  requireTemplate      Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model WorkspaceICP {
  id                  String    @id @default(cuid())
  workspaceId         String    @unique
  targetIndustries    String[]
  minEmployees        Int?
  maxEmployees        Int?
  targetGeos          String[]
  mustHaveEmail       Boolean   @default(false)
  businessType        String?
  outreachTone        String?   // professional | casual | direct
  approvalMode        Boolean   @default(true)
  dailySendLimit      Int       @default(50)
  excludedIndustries  String[]
  playbook            String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  workspace           Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}
