generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Append-only audit log of significant actions (sends, approvals, mission status
// changes, provider failures, api-key rotations). Deliberately FK-free so history
// survives deletion of the referenced entity.
model AuditEvent {
  id          String   @id @default(cuid())
  workspaceId String?
  actorUserId String?
  type        String
  entityType  String?
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([workspaceId, createdAt])
  @@index([type, createdAt])
}

// Audit log for prospect-discovery runs so users can tell "no prospects" apart
// from "the provider failed / quota exceeded / not configured", and see what was
// searched, returned, imported, and skipped per run.
model DiscoveryRun {
  id            String    @id @default(cuid())
  workspaceId   String
  source        String
  status        String    @default("RUNNING") // RUNNING | SUCCEEDED | PARTIAL | FAILED
  query         Json?
  resultCount   Int       @default(0)
  importedCount Int       @default(0)
  skippedCount  Int       @default(0)
  errorCode     String?
  errorMessage  String?
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, startedAt])
}

model User {
  id                  String                  @id @default(cuid())
  email               String                  @unique
  name                String?
  passwordHash        String?
  emailVerified       Boolean                 @default(false)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  memberships         Membership[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  emailVerifications  EmailVerificationToken[]
}

model Workspace {
  id                   String               @id @default(cuid())
  name                 String
  slug                 String               @unique
  plan                 String               @default("free")
  stripeCustomerId     String?              @unique
  stripeSubscriptionId String?              @unique
  subscriptionStatus   String?
  ingestApiKey         String?              @unique
  onboardingCompleted  Boolean              @default(false)
  senderBusinessName   String?
  senderPostalAddress  String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  memberships          Membership[]
  leads                Lead[]
  campaigns            Campaign[]
  outreachDrafts       OutreachDraft[]
  scoringModel         ScoringModel?
  usageRecords         UsageRecord[]
  prospects            Prospect[]
  signals              Signal[]
  recommendations      Recommendation[]
  prospectOutcomes     ProspectOutcome[]
  workspaceICP         WorkspaceICP?
  outreachSent         OutreachSent[]
  emailConfig          WorkspaceEmailConfig?
  invites              WorkspaceInvite[]
  suppressions         Suppression[]
  processedEmails      ProcessedEmail[]
  discoveryRuns        DiscoveryRun[]
  missions             Mission[]
}

model Membership {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  role        String
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([userId])
  @@index([workspaceId])
}

model Campaign {
  id           String         @id @default(cuid())
  workspaceId  String
  name         String
  goalType     String
  description  String?
  workspace    Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leads        Lead[]
  outreachSent OutreachSent[]
  mission      Mission?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([workspaceId])
}

// First-class Mission: the user-facing control plane that ties ICP/playbook,
// target + offer, and an execution Campaign into one workflow. The UI speaks
// "Mission"; this is its backing entity (previously the UI only created a
// Campaign). One Mission maps to one execution Campaign.
model Mission {
  id             String    @id @default(cuid())
  workspaceId    String
  name           String
  goalType       String
  targetCustomer String?
  offer          String?
  playbookId     String?
  status         String    @default("ACTIVE") // DRAFT | DISCOVERING | REVIEWING | ACTIVE | PAUSED | COMPLETE
  campaignId     String?   @unique
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign       Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
}

model Lead {
  id             String          @id @default(cuid())
  workspaceId    String
  campaignId     String?
  businessName   String
  contactName    String?
  email          String?
  phone          String?
  website        String?
  city           String?
  category       String?
  notes          String?
  aiSummary      String?
  outreachAngle  String?
  score          Int             @default(0)
  stage          LeadStage       @default(NEW)
  sourceTag      String?
  lastContactedAt DateTime?
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign       Campaign?       @relation(fields: [campaignId], references: [id])
  outreachDrafts OutreachDraft[]
  outreachSent   OutreachSent[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, stage])
  @@index([workspaceId, email])
  @@index([campaignId])
}

model OutreachDraft {
  id           String    @id @default(cuid())
  leadId       String
  workspaceId  String
  subject      String
  emailBody    String
  followup     String?
  status       DraftStatus @default(DRAFTED)
  reviewedAt   DateTime?
  reviewedBy   String?   // userId of approver/rejecter
  createdAt    DateTime  @default(now())
  lead         Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([workspaceId])
  @@index([workspaceId, status])
}

// Tracks every email sent via a campaign — provides closed-loop reply correlation.
// messageId is the SMTP Message-ID header; mailbox sync matches inbound replies
// against this column to update status to REPLIED and trigger AI analysis.
model OutreachSent {
  id               String    @id @default(cuid())
  workspaceId      String
  campaignId       String?
  leadId           String?
  toEmail          String
  subject          String
  body             String
  messageId        String?   @unique  // SMTP Message-ID for reply correlation
  // Outbox lifecycle: SENDING (claimed, pre-dispatch) -> SENT, or -> FAILED on a
  // known SMTP rejection. A crash after dispatch leaves the row SENDING
  // (fail-closed: never auto-resend). PENDING reserved for future pre-stage.
  status           String    @default("SENT")  // PENDING | SENDING | SENT | FAILED | BOUNCED | REPLIED
  lastError        String?
  repliedAt        DateTime?
  replyIntent      String?
  unsubscribeToken String?   @unique
  sentAt           DateTime  @default(now())
  workspace        Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign         Campaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  lead             Lead?      @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([campaignId])
  @@index([leadId])
  @@index([toEmail])
  // Outbox idempotency: at most one send row per (campaign, lead). Postgres
  // treats NULLs as distinct, so non-campaign/non-lead sends are unaffected.
  @@unique([campaignId, leadId])
}




// Persisted ScorerV2 model — one per workspace, survives deploys
model ScoringModel {
  id                 String           @id @default(cuid())
  workspaceId        String           @unique
  weights            Json
  signalWeights      Json?
  performanceMetrics Json
  updateCount        Int              @default(0)
  lastWeightUpdate   DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  workspace          Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  outcomes           ScoringOutcome[]
}

// Individual reply outcomes — feed the ScorerV2 feedback loop
model ScoringOutcome {
  id               String       @id @default(cuid())
  workspaceId      String
  leadId           String?
  // Nullable: reply outcomes sourced from a Lead (via the worker) have no
  // Prospect. Previously a Lead id was written here, corrupting the data.
  prospectId       String?
  score            Float
  replied          Boolean
  replyIntent      String?
  messageRelevance Float        @default(0.5)
  channelUsed      String       @default("EMAIL")
  scoringModelId   String
  scoringModel     ScoringModel @relation(fields: [scoringModelId], references: [id], onDelete: Cascade)
  recordedAt       DateTime     @default(now())

  @@index([workspaceId])
  @@index([scoringModelId])
  @@index([leadId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Monthly AI usage tracking for plan enforcement
model UsageRecord {
  id          String    @id @default(cuid())
  workspaceId String
  action      String    // AI_RESEARCH | AI_OUTREACH | AI_REPLY
  month       String    // YYYY-MM
  count       Int       @default(0)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, month, action])
  @@index([workspaceId])
}

// Deduplicate IMAP messages processed during mailbox sync.
// UIDs are only unique within a single mailbox, so they must be scoped by workspace.
model ProcessedEmail {
  id          String    @id @default(cuid())
  workspaceId String
  uid         Int
  messageId   String?
  fromAddress String?
  processedAt DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, uid])
  @@unique([workspaceId, messageId])
  @@index([workspaceId])
}

// Idempotency log for Stripe webhook events. Stripe delivers at-least-once and
// out of order; we record each processed event id so re-deliveries are ignored.
// Email invite for new users to join a workspace without a pre-existing account
model WorkspaceInvite {
  id          String    @id @default(cuid())
  workspaceId String
  email       String
  role        String    @default("member")
  tokenHash   String    @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, email])
  @@index([workspaceId])
}

// Per-workspace SMTP/IMAP credentials — falls back to env vars when absent
model WorkspaceEmailConfig {
  id          String    @id @default(cuid())
  workspaceId String    @unique
  smtpHost    String?
  smtpPort    Int?
  smtpSecure  Boolean   @default(false)
  smtpUser    String?
  smtpPass    String?
  smtpFrom    String?
  imapHost    String?
  imapPort    Int?
  imapSecure  Boolean   @default(true)
  imapUser    String?
  imapPass    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// Email address verification token sent on signup
model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Time-limited one-use token for password reset
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ProcessedStripeEvent {
  id          String   @id // Stripe event id (evt_...)
  type        String
  processedAt DateTime @default(now())
}

enum SignalType {
  HIRING
  FUNDING
  EXPANSION
  TECH_ADOPTION
  LEADERSHIP_CHANGE
  NEWS_MENTION
  PROCUREMENT
  BUSINESS_REGISTRATION
  WEBSITE_CHANGE
}

enum BuyingStage {
  RESEARCHING
  EVALUATING
  COMPARING
  PURCHASING
  INACTIVE
}

enum OutcomeStage {
  DISCOVERED
  VIEWED
  CONTACTED
  MEETING
  PROPOSAL
  WON
  LOST
}

// Outreach draft review state (gates approval-mode sends).
enum DraftStatus {
  DRAFTED
  APPROVED
  REJECTED
  SENT
  SKIPPED
}

// Lead pipeline stage (was a free-form String — now DB-enforced).
enum LeadStage {
  NEW
  RESEARCHED
  OUTREACH_SENT
  REPLIED
  BOOKED
  CLOSED
  DEAD
}

model Suppression {
  id          String    @id @default(cuid())
  workspaceId String
  email       String
  reason      String    @default("UNSUBSCRIBED") // UNSUBSCRIBED | BOUNCED | MANUAL
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, email])
  @@index([workspaceId])
}

model Prospect {
  id               String       @id @default(cuid())
  workspaceId      String
  companyName      String
  domain           String?
  domainKey        String?      // normalized domain: lowercased, www-stripped
  industry         String?
  employeeCount    Int?
  estimatedRevenue Int?    // cents
  location         String?
  description      String?
  notes            String?
  contactName      String?
  contactEmail     String?
  contactPhone     String?
  contactTitle     String?
  linkedinUrl      String?
  opportunityScore Int          @default(0)
  intentScore      Int          @default(0)
  fitScore         Int          @default(0)
  timingScore      Int          @default(0)
  confidenceScore  Int          @default(0)
  buyingStage      BuyingStage  @default(RESEARCHING)
  outcomeStage     OutcomeStage @default(DISCOVERED)
  expectedDealValue Int?   // cents
  winProbability   Float?
  lastSignalAt     DateTime?
  lastContactedAt  DateTime?
  aiSummary        String?
  sourceTag        String?
  isExample        Boolean      @default(false)
  workspace        Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  signals          Signal[]
  recommendations  Recommendation[]
  outcomes         ProspectOutcome[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, opportunityScore])
  @@index([workspaceId, buyingStage])
  @@index([workspaceId, outcomeStage])
  @@index([workspaceId, domainKey])
}

model Signal {
  id                String     @id @default(cuid())
  workspaceId       String
  prospectId        String
  type              SignalType
  strength          Int
  sourceReliability Int        @default(70)
  industryRelevance Int        @default(50)
  title             String?
  description       String?
  sourceUrl         String?
  source            String?
  fingerprint       String?    // dedup key: source:type:title-slug:YYYY-MM
  rawData           Json?
  detectedAt        DateTime   @default(now())
  workspace         Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  prospect          Prospect   @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  createdAt         DateTime   @default(now())

  @@unique([prospectId, fingerprint])
  @@index([workspaceId])
  @@index([prospectId])
  @@index([type])
  @@index([detectedAt])
}

model Recommendation {
  id           String    @id @default(cuid())
  workspaceId  String
  prospectId   String
  bestContact  String?
  bestTiming   String?
  bestChannel  String?
  messageAngle String?
  reasoning    String?
  actionText   String?
  urgency      String    @default("MEDIUM")
  priority     Int       @default(50)
  expiresAt    DateTime?
  actedAt      DateTime?
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  prospect     Prospect  @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())

  @@index([workspaceId])
  @@index([prospectId])
}

model ProspectOutcome {
  id          String       @id @default(cuid())
  workspaceId String
  prospectId  String
  stage       OutcomeStage
  notes       String?
  dealValue   Int?      // cents
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  prospect    Prospect     @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  recordedAt  DateTime     @default(now())

  @@index([workspaceId])
  @@index([prospectId])
}

model WorkspaceICP {
  id                  String    @id @default(cuid())
  workspaceId         String    @unique
  targetIndustries    String[]
  minEmployees        Int?
  maxEmployees        Int?
  targetGeos          String[]
  mustHaveEmail       Boolean   @default(false)
  businessType        String?
  outreachTone        String?   // professional | casual | direct
  approvalMode        Boolean   @default(true)
  dailySendLimit      Int       @default(50)
  excludedIndustries  String[]
  playbook            String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  workspace           Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}
