generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  passwordHash  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  memberships   Membership[]
  refreshTokens RefreshToken[]
}

model Workspace {
  id                   String          @id @default(cuid())
  name                 String
  slug                 String          @unique
  plan                 String          @default("free")
  stripeCustomerId     String?         @unique
  stripeSubscriptionId String?         @unique
  subscriptionStatus   String?
  ingestApiKey         String?         @unique
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  memberships          Membership[]
  leads                Lead[]
  campaigns            Campaign[]
  outreachDrafts       OutreachDraft[]
  scoringModel         ScoringModel?
  usageRecords         UsageRecord[]
  prospects            Prospect[]
  signals              Signal[]
  recommendations      Recommendation[]
  prospectOutcomes     ProspectOutcome[]
  workspaceICP         WorkspaceICP?
}

model Membership {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  role        String
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([userId])
  @@index([workspaceId])
}

model Campaign {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  goalType    String
  description String?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leads       Lead[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
}

model Lead {
  id             String          @id @default(cuid())
  workspaceId    String
  campaignId     String?
  businessName   String
  contactName    String?
  email          String?
  phone          String?
  website        String?
  city           String?
  category       String?
  notes          String?
  aiSummary      String?
  outreachAngle  String?
  score          Int             @default(0)
  stage          String          @default("NEW")
  sourceTag      String?
  lastContactedAt DateTime?
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign       Campaign?       @relation(fields: [campaignId], references: [id])
  outreachDrafts OutreachDraft[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, stage])
  @@index([workspaceId, email])
  @@index([campaignId])
}

model OutreachDraft {
  id          String    @id @default(cuid())
  leadId      String
  workspaceId String
  subject     String
  emailBody   String
  followup    String?
  createdAt   DateTime  @default(now())
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([workspaceId])
}

// Persisted ScorerV2 model — one per workspace, survives deploys
model ScoringModel {
  id                 String           @id @default(cuid())
  workspaceId        String           @unique
  weights            Json
  signalWeights      Json?
  performanceMetrics Json
  updateCount        Int              @default(0)
  lastWeightUpdate   DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  workspace          Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  outcomes           ScoringOutcome[]
}

// Individual reply outcomes — feed the ScorerV2 feedback loop
model ScoringOutcome {
  id               String       @id @default(cuid())
  workspaceId      String
  leadId           String?
  // Nullable: reply outcomes sourced from a Lead (via the worker) have no
  // Prospect. Previously a Lead id was written here, corrupting the data.
  prospectId       String?
  score            Float
  replied          Boolean
  replyIntent      String?
  messageRelevance Float        @default(0.5)
  channelUsed      String       @default("EMAIL")
  scoringModelId   String
  scoringModel     ScoringModel @relation(fields: [scoringModelId], references: [id], onDelete: Cascade)
  recordedAt       DateTime     @default(now())

  @@index([workspaceId])
  @@index([scoringModelId])
  @@index([leadId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Monthly AI usage tracking for plan enforcement
model UsageRecord {
  id          String    @id @default(cuid())
  workspaceId String
  action      String    // AI_RESEARCH | AI_OUTREACH | AI_REPLY
  month       String    // YYYY-MM
  count       Int       @default(0)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, month, action])
  @@index([workspaceId])
}

// Deduplicate IMAP messages processed during mailbox sync
model ProcessedEmail {
  id          String   @id @default(cuid())
  uid         Int      @unique
  messageId   String?  @unique
  fromAddress String?
  processedAt DateTime @default(now())
}

// Idempotency log for Stripe webhook events. Stripe delivers at-least-once and
// out of order; we record each processed event id so re-deliveries are ignored.
model ProcessedStripeEvent {
  id          String   @id // Stripe event id (evt_...)
  type        String
  processedAt DateTime @default(now())
}

enum SignalType {
  HIRING
  FUNDING
  EXPANSION
  TECH_ADOPTION
  LEADERSHIP_CHANGE
  NEWS_MENTION
  PROCUREMENT
  BUSINESS_REGISTRATION
  WEBSITE_CHANGE
}

enum BuyingStage {
  RESEARCHING
  EVALUATING
  COMPARING
  PURCHASING
  INACTIVE
}

enum OutcomeStage {
  DISCOVERED
  VIEWED
  CONTACTED
  MEETING
  PROPOSAL
  WON
  LOST
}

model Prospect {
  id               String       @id @default(cuid())
  workspaceId      String
  companyName      String
  domain           String?
  industry         String?
  employeeCount    Int?
  estimatedRevenue Float?
  location         String?
  description      String?
  notes            String?
  contactName      String?
  contactEmail     String?
  contactPhone     String?
  contactTitle     String?
  linkedinUrl      String?
  opportunityScore Int          @default(0)
  intentScore      Int          @default(0)
  fitScore         Int          @default(0)
  timingScore      Int          @default(0)
  confidenceScore  Int          @default(0)
  buyingStage      BuyingStage  @default(RESEARCHING)
  outcomeStage     OutcomeStage @default(DISCOVERED)
  expectedDealValue Float?
  winProbability   Float?
  lastSignalAt     DateTime?
  lastContactedAt  DateTime?
  aiSummary        String?
  sourceTag        String?
  workspace        Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  signals          Signal[]
  recommendations  Recommendation[]
  outcomes         ProspectOutcome[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, opportunityScore])
  @@index([workspaceId, buyingStage])
  @@index([workspaceId, outcomeStage])
}

model Signal {
  id                String     @id @default(cuid())
  workspaceId       String
  prospectId        String
  type              SignalType
  strength          Int
  sourceReliability Int        @default(70)
  industryRelevance Int        @default(50)
  title             String?
  description       String?
  sourceUrl         String?
  source            String?
  rawData           Json?
  detectedAt        DateTime   @default(now())
  workspace         Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  prospect          Prospect   @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  createdAt         DateTime   @default(now())

  @@index([workspaceId])
  @@index([prospectId])
  @@index([type])
  @@index([detectedAt])
}

model Recommendation {
  id           String    @id @default(cuid())
  workspaceId  String
  prospectId   String
  bestContact  String?
  bestTiming   String?
  bestChannel  String?
  messageAngle String?
  reasoning    String?
  actionText   String?
  urgency      String    @default("MEDIUM")
  priority     Int       @default(50)
  expiresAt    DateTime?
  actedAt      DateTime?
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  prospect     Prospect  @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())

  @@index([workspaceId])
  @@index([prospectId])
}

model ProspectOutcome {
  id          String       @id @default(cuid())
  workspaceId String
  prospectId  String
  stage       OutcomeStage
  notes       String?
  dealValue   Float?
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  prospect    Prospect     @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  recordedAt  DateTime     @default(now())

  @@index([workspaceId])
  @@index([prospectId])
}

model WorkspaceICP {
  id               String    @id @default(cuid())
  workspaceId      String    @unique
  targetIndustries String[]
  minEmployees     Int?
  maxEmployees     Int?
  targetGeos       String[]
  mustHaveEmail    Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}
