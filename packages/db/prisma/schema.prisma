generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  passwordHash  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  memberships   Membership[]
  refreshTokens RefreshToken[]
}

model Workspace {
  id                   String               @id @default(cuid())
  name                 String
  slug                 String               @unique
  plan                 String               @default("free")
  stripeCustomerId     String?              @unique
  stripeSubscriptionId String?              @unique
  subscriptionStatus   String?
  ingestApiKey         String?              @unique
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  memberships          Membership[]
  leads                Lead[]
  campaigns            Campaign[]
  outreachDrafts       OutreachDraft[]
  scoringModel         ScoringModel?
  usageRecords         UsageRecord[]
  prospects            Prospect[]
  signals              Signal[]
  recommendations      Recommendation[]
  prospectOutcomes     ProspectOutcome[]
  workspaceICP         WorkspaceICP?
  industryConfigs      IndustrySignalConfig[]
  messageExperiments   MessageExperiment[]
  messageOutcomes      MessageOutcome[]
}

model Membership {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  role        String
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([userId])
  @@index([workspaceId])
}

model Campaign {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  goalType    String
  description String?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leads       Lead[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
}

model Lead {
  id              String          @id @default(cuid())
  workspaceId     String
  campaignId      String?
  businessName    String
  contactName     String?
  email           String?
  phone           String?
  website         String?
  city            String?
  category        String?
  notes           String?
  aiSummary       String?
  outreachAngle   String?
  score           Int             @default(0)
  stage           String          @default("NEW")
  sourceTag       String?
  lastContactedAt DateTime?
  workspace       Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign        Campaign?       @relation(fields: [campaignId], references: [id])
  outreachDrafts  OutreachDraft[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, stage])
  @@index([workspaceId, email])
  @@index([campaignId])
}

model OutreachDraft {
  id          String    @id @default(cuid())
  leadId      String
  workspaceId String
  subject     String
  emailBody   String
  followup    String?
  createdAt   DateTime  @default(now())
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([workspaceId])
}

// Persisted scoring model — one per workspace, survives deploys
model ScoringModel {
  id                 String           @id @default(cuid())
  workspaceId        String           @unique
  weights            Json
  signalWeights      Json?
  channelWeights     Json?            // learned channel effectiveness per industry
  timingWeights      Json?            // learned best-timing patterns per segment
  performanceMetrics Json
  updateCount        Int              @default(0)
  lastWeightUpdate   DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  workspace          Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  outcomes           ScoringOutcome[]
}

// Individual reply outcomes — feed the ScorerV2 feedback loop
model ScoringOutcome {
  id               String       @id @default(cuid())
  workspaceId      String
  leadId           String?
  prospectId       String
  score            Float
  replied          Boolean
  replyIntent      String?
  messageRelevance Float        @default(0.5)
  channelUsed      String       @default("EMAIL")
  scoringModelId   String
  scoringModel     ScoringModel @relation(fields: [scoringModelId], references: [id], onDelete: Cascade)
  recordedAt       DateTime     @default(now())

  @@index([workspaceId])
  @@index([scoringModelId])
  @@index([leadId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Monthly AI usage tracking for plan enforcement
model UsageRecord {
  id          String    @id @default(cuid())
  workspaceId String
  action      String    // AI_RESEARCH | AI_OUTREACH | AI_REPLY
  month       String    // YYYY-MM
  count       Int       @default(0)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, month, action])
  @@index([workspaceId])
}

// Deduplicate IMAP messages processed during mailbox sync
model ProcessedEmail {
  id          String   @id @default(cuid())
  uid         Int      @unique
  messageId   String?  @unique
  fromAddress String?
  processedAt DateTime @default(now())
}

// ── Acquisition Intelligence enums ───────────────────────────────────────────

enum SignalType {
  // Broad acquisition signals
  HIRING
  FUNDING
  EXPANSION
  TECH_ADOPTION
  LEADERSHIP_CHANGE
  NEWS_MENTION
  PROCUREMENT
  BUSINESS_REGISTRATION
  WEBSITE_CHANGE
  // Granular acquisition signals for precision targeting
  JOB_POSTING_SPIKE
  CONTRACT_AWARDED
  TENDER_PUBLISHED
  PERMIT_APPROVED
  OFFICE_OPENING
  PRICING_PAGE_CHANGED
  ENTERPRISE_PAGE_LAUNCHED
  GOV_GRANT_RECEIVED
  PROJECT_START_DETECTED
  TECH_STACK_CHANGED
}

enum BuyingStage {
  RESEARCHING
  EVALUATING
  COMPARING
  PURCHASING
  INACTIVE
}

enum OutcomeStage {
  DISCOVERED
  VIEWED
  CONTACTED
  MEETING
  PROPOSAL
  WON
  LOST
}

enum MessageEvent {
  SENT
  OPENED
  CLICKED
  REPLIED
  MEETING_BOOKED
  PROPOSAL_SENT
  WON
  LOST
}

// ── Prospect intelligence models ──────────────────────────────────────────────

model Prospect {
  id                   String            @id @default(cuid())
  workspaceId          String
  companyName          String
  domain               String?
  industry             String?
  employeeCount        Int?
  estimatedRevenue     Float?
  location             String?
  description          String?
  notes                String?
  contactName          String?
  contactEmail         String?
  contactPhone         String?
  contactTitle         String?
  linkedinUrl          String?
  // Opportunity scoring (0-100 intelligence signal)
  opportunityScore     Int               @default(0)
  intentScore          Int               @default(0)
  fitScore             Int               @default(0)
  timingScore          Int               @default(0)
  confidenceScore      Int               @default(0)
  buyingStage          BuyingStage       @default(RESEARCHING)
  outcomeStage         OutcomeStage      @default(DISCOVERED)
  // Expected revenue scoring (dollar-weighted ranking)
  expectedDealValue    Float?
  winProbability       Float?
  retentionProbability Float             @default(0.8)
  expansionProbability Float             @default(0.2)
  expectedRevenueScore Float             @default(0)
  lastSignalAt         DateTime?
  lastContactedAt      DateTime?
  aiSummary            String?
  sourceTag            String?
  workspace            Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  signals              Signal[]
  recommendations      Recommendation[]
  outcomes             ProspectOutcome[]
  messageOutcomes      MessageOutcome[]
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, opportunityScore])
  @@index([workspaceId, expectedRevenueScore])
  @@index([workspaceId, buyingStage])
  @@index([workspaceId, outcomeStage])
}

model Signal {
  id                String     @id @default(cuid())
  workspaceId       String
  prospectId        String
  type              SignalType
  // Raw event data
  rawType           String?    // original type string before normalization
  normalizedType    String?    // normalized category: growth|efficiency|cost_reduction|risk
  category          String?    // high-level: operational|financial|digital|market
  // Signal quality
  strength          Int
  confidence        Int        @default(70)  // 0-100 confidence in signal accuracy
  sourceReliability Int        @default(70)
  industryRelevance Int        @default(50)
  // Buying intelligence
  buyingImplication String?    // e.g. "likely_operational_pressure"
  predictedNeeds    String[]   // e.g. ["labour","workflow_software","subcontractors"]
  // Evidence
  title             String?
  description       String?
  sourceUrl         String?
  evidenceUrl       String?
  source            String?
  rawData           Json?
  // Lifecycle
  detectedAt        DateTime   @default(now())
  expiresAt         DateTime?  // pre-computed decay deadline
  workspace         Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  prospect          Prospect   @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  createdAt         DateTime   @default(now())

  @@index([workspaceId])
  @@index([prospectId])
  @@index([type])
  @@index([detectedAt])
  @@index([expiresAt])
}

// Strategy card — intelligence output for a prospect
model Recommendation {
  id                 String    @id @default(cuid())
  workspaceId        String
  prospectId         String
  // Action intelligence
  bestContact        String?
  bestTiming         String?
  bestChannel        String?
  messageAngle       String?
  reasoning          String?
  actionText         String?
  urgency            String    @default("MEDIUM")
  priority           Int       @default(50)
  // Strategy card extensions
  predictedNeed      String?   // e.g. "workforce coordination software"
  meetingProbability Float?    // 0.0-1.0
  expectedRevenue    Float?    // dollar value of this opportunity
  expiresAt          DateTime?
  actedAt            DateTime?
  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  prospect           Prospect  @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  createdAt          DateTime  @default(now())

  @@index([workspaceId])
  @@index([prospectId])
}

model ProspectOutcome {
  id          String       @id @default(cuid())
  workspaceId String
  prospectId  String
  stage       OutcomeStage
  notes       String?
  dealValue   Float?
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  prospect    Prospect     @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  recordedAt  DateTime     @default(now())

  @@index([workspaceId])
  @@index([prospectId])
}

model WorkspaceICP {
  id               String    @id @default(cuid())
  workspaceId      String    @unique
  targetIndustries String[]
  minEmployees     Int?
  maxEmployees     Int?
  targetGeos       String[]
  mustHaveEmail    Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// Per-workspace database-backed industry signal weight matrix
model IndustrySignalConfig {
  id           String    @id @default(cuid())
  workspaceId  String
  industry     String    // e.g. "construction", "logistics", "saas"
  signalBoosts Json      // { CONTRACT_AWARDED: 100, TENDER_PUBLISHED: 100, ... }
  description  String?   // human-readable note
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([workspaceId, industry])
  @@index([workspaceId])
}

// ── Message Intelligence models ───────────────────────────────────────────────

// Tracks message variants for A/B learning
model MessageExperiment {
  id                  String           @id @default(cuid())
  workspaceId         String
  name                String
  subject             String?
  painAngle           String?          // e.g. "labour_shortage", "cost_reduction"
  ctaType             String?          // e.g. "book_call", "demo_request", "reply"
  industry            String?
  channel             String           // EMAIL | LINKEDIN | PHONE
  messageLength       Int?
  personalizationType String?          // e.g. "signal_based", "industry", "generic"
  timing              String?          // e.g. "tuesday_morning", "end_of_quarter"
  workspace           Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  outcomes            MessageOutcome[]
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, channel])
  @@index([workspaceId, industry])
}

// Individual message outcome — feeds message-market fit learning
model MessageOutcome {
  id           String             @id @default(cuid())
  workspaceId  String
  experimentId String?
  prospectId   String?
  event        MessageEvent
  channel      String
  sentAt       DateTime?
  respondedAt  DateTime?          // first meaningful response timestamp
  dealValue    Float?
  notes        String?
  workspace    Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  experiment   MessageExperiment? @relation(fields: [experimentId], references: [id])
  prospect     Prospect?          @relation(fields: [prospectId], references: [id])
  createdAt    DateTime           @default(now())

  @@index([workspaceId])
  @@index([experimentId])
  @@index([prospectId])
  @@index([workspaceId, event])
  @@index([workspaceId, channel])
}
