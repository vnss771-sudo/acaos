# Pinned to the immutable multi-arch index digest for reproducible builds; the
# tag is kept as a comment for readability. Dependabot (docker ecosystem) bumps
# the digest+tag. Re-resolve with:
#   docker buildx imagetools inspect node:22-alpine --format '{{json .Manifest.Digest}}'
FROM node:22-alpine@sha256:ab07539e0988b63558ff621f5fbe1077054c39d9809112974fb79993949d41cd AS builder # node:22-alpine
WORKDIR /app

COPY package.json package-lock.json ./
COPY packages/shared/package.json ./packages/shared/
COPY apps/web/package.json ./apps/web/
# scripts/ must exist before `npm ci` so the root postinstall script is present
# (it no-ops here — the Prisma schema isn't part of the web build context).
COPY scripts ./scripts

# --include=dev so vite/typescript (devDependencies) are present for the build
# even when NODE_ENV=production is injected into the build env (Railway).
RUN npm ci --include=dev --ignore-optional

COPY packages/shared ./packages/shared
COPY apps/web ./apps/web

ARG VITE_API_BASE_URL
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL

RUN npm --workspace @acaos/web run build

# Pinned to the immutable multi-arch index digest; tag kept as a comment.
# Re-resolve with:
#   docker buildx imagetools inspect nginx:alpine --format '{{json .Manifest.Digest}}'
FROM nginx:alpine@sha256:20316569d8f81a160065d7d2a5eeffc7ca97d79022462ee255fd23fa103a6b5c # nginx:alpine
COPY --from=builder /app/apps/web/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
