# Pinned to the immutable multi-arch index digest for reproducible builds; the
# tag is kept as a comment for readability. Dependabot (docker ecosystem) bumps
# the digest+tag. Re-resolve with:
#   docker buildx imagetools inspect node:22-alpine --format '{{json .Manifest.Digest}}'
FROM node:26-alpine@sha256:a2dc166a387cc6ca1e62d0c8e265e49ca985d6e60abc9fe6e6c3d6ce8e63f606 AS builder
WORKDIR /app

COPY package.json package-lock.json ./
COPY packages/shared/package.json ./packages/shared/
COPY apps/web/package.json ./apps/web/
# scripts/ must exist before `npm ci` so the root postinstall script is present
# (it no-ops here — the Prisma schema isn't part of the web build context).
COPY scripts ./scripts

# --include=dev so vite/typescript (devDependencies) are present for the build
# even when NODE_ENV=production is injected into the build env (Railway).
RUN npm ci --include=dev --ignore-optional

COPY packages/shared ./packages/shared
COPY apps/web ./apps/web

ARG VITE_API_BASE_URL
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL

RUN npm --workspace @acaos/web run build

# Unprivileged nginx: runs as UID 101 (non-root), writes its pid + temp paths
# under /tmp, and listens on 8080 by default — no root, no Linux capabilities
# needed to bind a privileged port. Pinned to the immutable multi-arch index
# digest (covers amd64 + arm64); tag kept as a comment. Dependabot (docker
# ecosystem) bumps the digest+tag. Re-resolve with:
#   docker buildx imagetools inspect nginxinc/nginx-unprivileged:alpine --format '{{json .Manifest.Digest}}'
FROM nginxinc/nginx-unprivileged:alpine@sha256:26b5d4920434bc4d8c17a68201488cf4b3d2391f0d25305cdfe66ccdc6d18aa4
# COPY runs as root (build daemon) regardless of the base image's USER 101, so
# the SPA assets and our hardened server block land readable by the nginx user.
COPY --from=builder /app/apps/web/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Non-privileged listen port (see `listen 8080` in nginx.conf). The container
# still runs as USER 101 inherited from the base image.
EXPOSE 8080
CMD ["nginx", "-g", "daemon off;"]
