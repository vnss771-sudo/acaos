# ── API ────────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
API_URL=http://localhost:4000
WEB_URL=http://localhost:5173
APP_URL=http://localhost:5173   # Public URL of the web app — used in email links
# Comma-separated exact origins allowed by CORS in production (no wildcards).
# Falls back to WEB_URL if unset. Only needed when the web app is served from a
# DIFFERENT origin than the API. The supported production topology serves the
# built SPA from the SAME origin as the API (see WEB_DIST_DIR below), in which
# case there are no cross-origin requests and this can be left unset.
ALLOWED_ORIGINS=http://localhost:5173

# Directory holding the built web SPA. When set (and present), the API serves the
# frontend from its own origin, so the whole app runs on one URL — the supported
# production topology, required by the first-party refresh-token cookie. The
# Docker image sets this automatically; leave blank for the local Vite dev server.
# WEB_DIST_DIR=/app/apps/web/dist

# ── Auth ───────────────────────────────────────────────────────────────────────
# REQUIRED in production. Must be a strong random value, >= 16 chars, and never
# the literal "change-me". Generate with: openssl rand -hex 32
# Leave UNSET in development — a random ephemeral secret is used automatically.
JWT_SECRET=
JWT_EXPIRES_IN=15m         # Access token TTL (short — 15 minutes recommended)
REFRESH_TOKEN_DAYS=30      # Refresh token TTL in days

# Refresh-token cookie (HttpOnly). The refresh token is delivered as a first-party
# cookie, so in production the API and web app MUST be same-site (e.g. acaos.app +
# api.acaos.app); cross-site/third-party cookies are blocked by Safari and being
# phased out by Chrome. SameSite=Lax is the default and recommended.
COOKIE_SAMESITE=lax        # lax | strict | none  (none requires Secure + same site not enforced)
# COOKIE_SECURE defaults to true in production (and is forced on for SameSite=none).
# Set to false only for local non-HTTPS testing if needed.
# COOKIE_SECURE=true

# ── Frontend ───────────────────────────────────────────────────────────────────
# Leave blank for same-origin serving (the SPA calls /api on its own origin) and
# for the local Vite proxy. Only set to the API URL if the frontend is deployed
# to a separate origin.
VITE_API_BASE_URL=
VITE_STRIPE_PRICE_STARTER=  # Optional: expose price IDs to frontend for plan selection
VITE_STRIPE_PRICE_GROWTH=

# ── Database ───────────────────────────────────────────────────────────────────
# Add ?connection_limit=3&pool_timeout=20 when running multiple API pods.
# Add ?pgbouncer=true to the above when behind PgBouncer (transaction mode).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/acaos?schema=public
# Only required when DATABASE_URL points at PgBouncer — used by Prisma migrations
# to bypass the pooler and connect directly. Leave blank otherwise.
DIRECT_URL=

# ── Redis / BullMQ ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Apollo.io (prospect discovery + enrichment — optional) ────────────────────
APOLLO_API_KEY=

# ── Hunter.io (email finder — optional) ───────────────────────────────────────
HUNTER_API_KEY=

# ── Google Places (local business discovery — optional) ───────────────────────
GOOGLE_PLACES_API_KEY=

# ── Admin panel (single-admin email gate) ─────────────────────────────────────
ADMIN_EMAIL=                  # Server-side admin check (e.g. you@yourdomain.com)
VITE_ADMIN_EMAIL=             # Must match ADMIN_EMAIL — used by frontend to show admin link

# ── Worker ─────────────────────────────────────────────────────────────────────
WORKER_HEALTH_PORT=9090       # Port for the worker liveness probe HTTP server

# ── Workspace email credentials encryption ─────────────────────────────────────
# REQUIRED in production when per-workspace SMTP/IMAP credentials are stored.
# Generate with: openssl rand -hex 64
# Leave blank in development (falls back to insecure zero-key — dev only).
EMAIL_ENCRYPTION_KEY=

# ── IMAP tuning ────────────────────────────────────────────────────────────────
IMAP_SOCKET_TIMEOUT_MS=30000  # IMAP socket idle timeout in ms

# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=       # Obtained from Stripe dashboard after adding webhook endpoint
STRIPE_PRICE_STARTER=        # Price ID for Starter plan (e.g. price_1234...)
STRIPE_PRICE_GROWTH=         # Price ID for Growth plan

# ── Mail (SMTP outbound) ───────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# ── Mail (IMAP inbound) ────────────────────────────────────────────────────────
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
IMAP_SECURE=true
