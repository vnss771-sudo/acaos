# ── API ────────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
API_URL=http://localhost:4000
WEB_URL=http://localhost:5173
APP_URL=http://localhost:5173   # Public URL of the web app — used in email links
# Comma-separated exact origins allowed by CORS in production (no wildcards).
# Falls back to WEB_URL if unset. Required in production.
ALLOWED_ORIGINS=http://localhost:5173

# ── Auth ───────────────────────────────────────────────────────────────────────
# REQUIRED in production. Must be a strong random value, >= 16 chars, and never
# the literal "change-me". Generate with: openssl rand -hex 32
# Leave UNSET in development — a random ephemeral secret is used automatically.
JWT_SECRET=
JWT_EXPIRES_IN=15m         # Access token TTL (short — 15 minutes recommended)
REFRESH_TOKEN_DAYS=30      # Refresh token TTL in days

# Refresh-token cookie (HttpOnly). The refresh token is delivered as a first-party
# cookie, so in production the API and web app MUST be same-site (e.g. acaos.app +
# api.acaos.app); cross-site/third-party cookies are blocked by Safari and being
# phased out by Chrome. SameSite=Lax is the default and recommended.
COOKIE_SAMESITE=lax        # lax | strict | none  (none requires Secure + same site not enforced)
# COOKIE_SECURE defaults to true in production (and is forced on for SameSite=none).
# Set to false only for local non-HTTPS testing if needed.
# COOKIE_SECURE=true

# ── Security / step-up ─────────────────────────────────────────────────────────
# Freshness window (minutes) for step-up re-auth on sensitive mutations (billing,
# admin promotion, MFA disable). A recent re-auth within this window satisfies the
# step-up check; older ones force a fresh re-auth. Optional.
STEP_UP_MAX_AGE_MIN=15

# ── Frontend ───────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=          # Leave blank when using Vite proxy; set to API_URL in prod
VITE_STRIPE_PRICE_STARTER=  # Optional: expose price IDs to frontend for plan selection
VITE_STRIPE_PRICE_GROWTH=

# ── Database ───────────────────────────────────────────────────────────────────
# Add ?connection_limit=3&pool_timeout=20 when running multiple API pods.
# Add ?pgbouncer=true to the above when behind PgBouncer (transaction mode).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/acaos?schema=public
# Only required when DATABASE_URL points at PgBouncer — used by Prisma migrations
# to bypass the pooler and connect directly. Leave blank otherwise.
DIRECT_URL=

# ── Redis / BullMQ ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Apollo.io (prospect discovery + enrichment — optional) ────────────────────
APOLLO_API_KEY=

# ── Hunter.io (email finder — optional) ───────────────────────────────────────
HUNTER_API_KEY=

# ── Google Places (local business discovery — optional) ───────────────────────
GOOGLE_PLACES_API_KEY=

# ── Admin panel ───────────────────────────────────────────────────────────────
# Authority is the non-user-settable User.isPlatformAdmin DB flag. ADMIN_EMAIL is
# a ONE-TIME bootstrap, not a perpetual fallback: the first time a verified user
# whose address matches it reaches an admin route, they are promoted to the DB
# flag and the grant is written to the audit log. After that the flag is the sole
# source of truth and ADMIN_EMAIL can be safely removed.
ADMIN_EMAIL=                  # One-time platform-admin bootstrap (e.g. you@yourdomain.com)
# NOTE: VITE_ADMIN_EMAIL is no longer used. The web client gates the admin UI on
# the backend's isPlatformAdmin claim (returned by /api/auth/me), not a build-time
# env var, so the link can never drift from the server-side grant.

# ── Worker ─────────────────────────────────────────────────────────────────────
WORKER_HEALTH_PORT=9090       # Port for the worker liveness probe HTTP server

# ── Workspace email credentials encryption ─────────────────────────────────────
# REQUIRED in production when per-workspace SMTP/IMAP credentials are stored.
# Generate with: openssl rand -hex 64
# Leave blank in development (falls back to insecure zero-key — dev only).
EMAIL_ENCRYPTION_KEY=

# ── IMAP tuning ────────────────────────────────────────────────────────────────
IMAP_SOCKET_TIMEOUT_MS=30000  # IMAP socket idle timeout in ms

# ── Performance tuning ───────────────────────────────────────────────────────────
# GET /api/stats coalesces concurrent requests per workspace (single-flight) and
# serves the result for this many ms. 0 = pure single-flight (no stale reads).
STATS_CACHE_TTL_MS=5000

# ── Data retention ─────────────────────────────────────────────────────────────
# The worker periodically purges aged data. RETENTION_PURGE_INTERVAL_MS controls
# how often the purge job runs; the per-class *_DAYS windows control how long each
# data class is kept before purge (they override the defaults in
# docs/DATA_RETENTION.md). All optional.
RETENTION_PURGE_INTERVAL_MS=86400000   # How often to run the purge job, in ms (default 24h)
RETENTION_PROCESSED_EMAIL_DAYS=90      # Retain processed inbound emails (days)
RETENTION_OUTREACH_SENT_DAYS=548       # Retain sent outreach records (days, ~18mo)
RETENTION_DISCOVERY_RUN_DAYS=365       # Retain discovery run history (days)
RETENTION_AUDIT_EVENT_DAYS=730         # Retain audit events (days, ~24mo)
RETENTION_STRIPE_EVENT_DAYS=365        # Retain stored Stripe events (days)
RETENTION_AUTH_TOKEN_DAYS=30           # Retain expired/revoked auth tokens (days)

# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=       # Obtained from Stripe dashboard after adding webhook endpoint
STRIPE_PRICE_STARTER=        # Price ID for Starter plan (e.g. price_1234...)
STRIPE_PRICE_GROWTH=         # Price ID for Growth plan

# ── Mail (SMTP outbound) ───────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# ── Mail (IMAP inbound) ────────────────────────────────────────────────────────
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
IMAP_SECURE=true

# ── Observability ──────────────────────────────────────────────────────────────
# Prometheus scrape endpoint is served at GET /metrics. When METRICS_TOKEN is set,
# scrapers must send `Authorization: Bearer <token>`; leave blank to expose it
# openly (e.g. on a private network / in dev).
METRICS_TOKEN=

# Error reporting (optional). Set to a Sentry DSN to forward unhandled API/worker
# errors to Sentry. Requires @sentry/node to be installed; if unset (or the SDK
# is absent) error reporting is disabled and the app behaves exactly as before.
SENTRY_DSN=
