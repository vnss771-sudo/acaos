# ── API ────────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
API_URL=http://localhost:4000
WEB_URL=http://localhost:5173

# ── Auth ───────────────────────────────────────────────────────────────────────
# IMPORTANT: Change JWT_SECRET to a strong random value in production
JWT_SECRET=change-me
JWT_EXPIRES_IN=15m         # Access token TTL (short — 15 minutes recommended)
REFRESH_TOKEN_DAYS=30      # Refresh token TTL in days

# ── Frontend ───────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=          # Leave blank when using Vite proxy; set to API_URL in prod
VITE_STRIPE_PRICE_STARTER=  # Optional: expose price IDs to frontend for plan selection
VITE_STRIPE_PRICE_GROWTH=

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/acaos?schema=public

# ── Redis / BullMQ ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Apollo.io (prospect enrichment — optional) ─────────────────────────────────
APOLLO_API_KEY=

# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=       # Obtained from Stripe dashboard after adding webhook endpoint
STRIPE_PRICE_STARTER=        # Price ID for Starter plan (e.g. price_1234...)
STRIPE_PRICE_GROWTH=         # Price ID for Growth plan

# ── Mail (SMTP outbound) ───────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# ── Mail (IMAP inbound) ────────────────────────────────────────────────────────
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
IMAP_SECURE=true
