# Core connection/secret vars to boot ACAOS. The FULL runtime config reference —
# every operational toggle and tuning knob with its default, scope, and whether
# production requires it — lives in docs/CONFIGURATION.md.

# ── API ────────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

API_URL=http://localhost:4000
WEB_URL=http://localhost:5173
APP_URL=http://localhost:5173

# Comma-separated exact origins allowed by CORS in production.
# No wildcards. Falls back to WEB_URL if unset.
ALLOWED_ORIGINS=http://localhost:5173

# ── Auth ───────────────────────────────────────────────────────────────────────
# REQUIRED in production.
# Must be a strong random value, >= 16 chars, and never "change-me".
# Generate with:
# openssl rand -hex 32
#
# Leave unset in development. A random ephemeral secret is used automatically.
JWT_SECRET=

# Access token TTL. Short values are recommended.
JWT_EXPIRES_IN=15m

# Refresh token TTL in days.
REFRESH_TOKEN_DAYS=30

# Refresh-token cookie SameSite policy.
# Recommended default: lax
# Allowed values: lax, strict, none
# "none" requires Secure cookies and HTTPS.
COOKIE_SAMESITE=lax

# COOKIE_SECURE defaults to true in production.
# Set false only for local non-HTTPS testing when needed.
# COOKIE_SECURE=true

# ── Security / step-up ─────────────────────────────────────────────────────────
# Freshness window, in minutes, for step-up re-auth on sensitive mutations.
STEP_UP_MAX_AGE_MIN=15

# ── Frontend ───────────────────────────────────────────────────────────────────
# Leave blank when using the Vite proxy locally.
# Set to API_URL in production when needed.
VITE_API_BASE_URL=

# Optional: expose Stripe price IDs to the frontend for plan selection.
VITE_STRIPE_PRICE_STARTER=
VITE_STRIPE_PRICE_GROWTH=

# ── Database ───────────────────────────────────────────────────────────────────
# Add ?connection_limit=3&pool_timeout=20 when running multiple API pods.
# Add ?pgbouncer=true when connecting through PgBouncer transaction mode.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/acaos?schema=public

# Required only when DATABASE_URL points at PgBouncer.
# Prisma migrations should use this direct connection instead of the pooler.
DIRECT_URL=

# ── Redis / BullMQ ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Discovery / enrichment providers ───────────────────────────────────────────
APOLLO_API_KEY=
HUNTER_API_KEY=
GOOGLE_PLACES_API_KEY=

# ── Admin panel ────────────────────────────────────────────────────────────────
# One-time platform-admin bootstrap email.
# The first verified user matching this email can be promoted to the DB-backed
# User.isPlatformAdmin flag. Remove after bootstrap.
ADMIN_EMAIL=

# VITE_ADMIN_EMAIL is intentionally not used.
# The web client should trust only the backend isPlatformAdmin claim.

# ── Worker ─────────────────────────────────────────────────────────────────────
WORKER_HEALTH_PORT=9090

# ── Workspace email credentials encryption ─────────────────────────────────────
# REQUIRED in production when per-workspace SMTP/IMAP credentials are stored.
# Generate with:
# openssl rand -hex 64
#
# Leave blank in development.
EMAIL_ENCRYPTION_KEY=

# ── IMAP tuning ────────────────────────────────────────────────────────────────
IMAP_SOCKET_TIMEOUT_MS=30000

# ── Performance tuning ─────────────────────────────────────────────────────────
# GET /api/stats coalesces concurrent requests per workspace and serves the
# result for this many milliseconds. Use 0 for pure single-flight behavior.
STATS_CACHE_TTL_MS=5000

# ── Data retention ─────────────────────────────────────────────────────────────
RETENTION_PURGE_INTERVAL_MS=86400000
RETENTION_PROCESSED_EMAIL_DAYS=90
RETENTION_OUTREACH_SENT_DAYS=548
RETENTION_DISCOVERY_RUN_DAYS=365
RETENTION_AUDIT_EVENT_DAYS=730
RETENTION_ANALYTICS_EVENT_DAYS=365
RETENTION_STRIPE_EVENT_DAYS=365
RETENTION_AUTH_TOKEN_DAYS=30

# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=

# ── Mail: SMTP outbound ────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# ── Mail: IMAP inbound ─────────────────────────────────────────────────────────
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
IMAP_SECURE=true

# ── Observability ──────────────────────────────────────────────────────────────
# Prometheus scrape endpoint is served at GET /metrics.
# When METRICS_TOKEN is set, scrapers must send:
# Authorization: Bearer <token>
METRICS_TOKEN=

# Optional Sentry DSN.
# If unset, error reporting is disabled.
SENTRY_DSN=
