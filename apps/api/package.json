{
  "name": "@acaos/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=--conditions=acaos-src tsx watch src/server.ts",
    "build": "node ../../scripts/ensure-prisma-client.mjs && tsc -p ../../packages/backend-core/tsconfig.json && tsc -p tsconfig.json",
    "migrate": "npx prisma migrate deploy --schema ../../packages/db/prisma/schema.prisma",
    "start": "node dist/server.js",
    "start:dev": "NODE_OPTIONS=--conditions=acaos-src tsx src/server.ts"
  },
  "dependencies": {
    "@acaos/shared": "*",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "imapflow": "^1.4.2",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^9.0.1",
    "openai": "^6.0.0",
    "prisma": "^7.8.0",
    "stripe": "^22.2.2",
    "zod": "^4.4.3",
    "@acaos/backend-core": "*"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
