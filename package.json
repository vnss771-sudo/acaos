{
  "name": "acaos-production-enhanced",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace @acaos/web run dev",
    "dev:api": "npm --workspace @acaos/api run dev",
    "dev:worker": "npm --workspace @acaos/worker run dev",
    "dev": "echo Run dev:web, dev:api and dev:worker in separate terminals",
    "prisma:generate": "npm --workspace @acaos/db run prisma:generate",
    "prisma:migrate": "npm --workspace @acaos/db run prisma:migrate",
    "build": "npm --workspace @acaos/web run build",
    "typecheck:api": "tsc --noEmit -p apps/api/tsconfig.json",
    "typecheck:web": "tsc --noEmit -p apps/web/tsconfig.json",
    "typecheck:worker": "tsc --noEmit -p apps/worker/tsconfig.json",
    "typecheck": "npm run typecheck:api && npm run typecheck:web && npm run typecheck:worker",
    "test": "tsx --test --test-force-exit tests/**/*.test.ts",
    "test:coverage": "tsx --test --experimental-test-coverage --test-coverage-exclude='tests/**' --test-coverage-lines=80 --test-coverage-branches=65 --test-coverage-functions=80 --test-force-exit tests/**/*.test.ts",
    "test:db": "tsx --test --test-concurrency=1 --test-force-exit tests-db/**/*.test.ts",
    "test:db:local": "bash scripts/test-db-local.sh",
    "test:redis": "tsx --test --test-concurrency=1 --test-force-exit tests-redis/**/*.test.ts",
    "test:redis:local": "bash scripts/test-redis-local.sh",
    "test:web": "npm test -w @acaos/web",
    "smoke:api": "node scripts/smoke-api-health.mjs"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "tsx": "^4.20.6"
  }
}
